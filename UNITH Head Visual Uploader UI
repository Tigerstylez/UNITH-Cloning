<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UNITH | Head Visual Upload Portal</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top right, #1e3a8a 0%, #020617 100%);
            color: #f8fafc;
            min-height: 100vh;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .upload-zone {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .upload-zone:hover {
            background: rgba(59, 130, 246, 0.05);
            border-color: #3b82f6;
        }

        .gradient-text {
            background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .step-active {
            border-color: #3b82f6;
            background: rgba(59, 130, 246, 0.1);
        }

        @keyframes pulse-border {
            0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); }
            100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
        }

        .loading-pulse {
            animation: pulse-border 2s infinite;
        }
    </style>
</head>
<body class="antialiased overflow-x-hidden">

    <!-- Header / Navigation -->
    <nav class="flex items-center justify-between px-8 py-6 max-w-7xl mx-auto">
        <div class="flex items-center space-x-2">
            <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
                <i data-lucide="scan-face" class="text-white"></i>
            </div>
            <span class="text-xl font-bold tracking-tight">UNITH <span class="text-blue-400">Labs</span></span>
        </div>
        <div class="hidden md:flex items-center space-x-8 text-sm font-medium text-slate-400">
            <a href="#" class="hover:text-white transition">Documentation</a>
            <a href="#" class="hover:text-white transition">Guidelines</a>
            <a href="#" class="bg-white/10 px-4 py-2 rounded-full text-white hover:bg-white/20 transition">Manage Account</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto px-6 pt-12 pb-24">
        <!-- Hero Section -->
        <div class="text-center mb-16">
            <h1 class="text-5xl font-extrabold mb-4 tracking-tight">Create your <span class="gradient-text">Digital Clone</span></h1>
            <p class="text-slate-400 text-lg max-w-2xl mx-auto">
                Transform high-fidelity video recordings into intelligent Digital Human visuals. 
                Follow our strict recording standards for the best results.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Sidebar -->
            <div class="lg:col-span-1 space-y-6">
                <div class="glass-panel rounded-3xl p-6">
                    <h3 class="font-bold text-sm uppercase tracking-widest text-blue-400 mb-6 flex items-center">
                        <i data-lucide="check-circle-2" class="w-4 h-4 mr-2"></i> Quality Checklist
                    </h3>
                    <ul class="space-y-4 text-sm text-slate-300">
                        <li class="flex items-start">
                            <i data-lucide="aspect-ratio" class="w-4 h-4 mr-3 text-blue-500 mt-0.5"></i>
                            <span>16:9 Aspect Ratio (Landscape)</span>
                        </li>
                        <li class="flex items-start">
                            <i data-lucide="timer" class="w-4 h-4 mr-3 text-blue-500 mt-0.5"></i>
                            <span>Duration: Exactly 10 seconds</span>
                        </li>
                        <li class="flex items-start">
                            <i data-lucide="video" class="w-4 h-4 mr-3 text-blue-500 mt-0.5"></i>
                            <span>Resolution: 1080p (Preferred)</span>
                        </li>
                        <li class="flex items-start">
                            <i data-lucide="repeat" class="w-4 h-4 mr-3 text-blue-500 mt-0.5"></i>
                            <span>Seamless Loop (Start/End Match)</span>
                        </li>
                    </ul>
                </div>

                <div class="p-6 bg-blue-600/10 border border-blue-500/20 rounded-3xl text-xs text-blue-300">
                    <p><span class="font-bold block mb-1">API Endpoint:</span> 
                    <code class="text-blue-100">POST /head-visuals</code></p>
                </div>
            </div>

            <!-- Main Upload Form -->
            <div class="lg:col-span-2 space-y-6">
                <div class="glass-panel rounded-3xl p-8">
                    <form id="uploadForm" class="space-y-8">
                        <!-- Step 1: Authentication -->
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <label class="text-sm font-semibold text-slate-300">Bearer Token</label>
                                <span class="text-[10px] text-slate-500 bg-white/5 px-2 py-1 rounded">Exp: 7 Days</span>
                            </div>
                            <div class="relative">
                                <i data-lucide="key" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500"></i>
                                <input type="password" id="bearerToken" required 
                                    class="w-full bg-black/40 border border-white/10 rounded-2xl pl-12 pr-4 py-4 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition text-sm"
                                    placeholder="paste_your_long_token_here">
                            </div>
                        </div>

                        <!-- Step 2: File Upload -->
                        <div class="space-y-4">
                            <label class="text-sm font-semibold text-slate-300">Recording Visual (MP4)</label>
                            <div id="dropZone" class="upload-zone border-2 border-dashed border-white/10 rounded-3xl p-12 text-center cursor-pointer relative group">
                                <input type="file" id="videoFile" accept="video/mp4" class="hidden">
                                <div id="previewContainer" class="hidden absolute inset-0 rounded-3xl overflow-hidden bg-black">
                                    <video id="videoPreview" class="w-full h-full object-cover opacity-60" loop muted></video>
                                    <div class="absolute inset-0 flex items-center justify-center">
                                        <button type="button" onclick="resetUpload()" class="bg-white/10 hover:bg-white/20 p-2 rounded-full backdrop-blur-md transition">
                                            <i data-lucide="x" class="w-5 h-5"></i>
                                        </button>
                                    </div>
                                </div>
                                <div id="uploadPrompt" class="space-y-4">
                                    <div class="w-16 h-16 bg-blue-500/10 rounded-full flex items-center justify-center mx-auto group-hover:scale-110 transition">
                                        <i data-lucide="upload-cloud" class="text-blue-500 w-8 h-8"></i>
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium">Click to upload or drag & drop</p>
                                        <p class="text-xs text-slate-500 mt-1">MP4 (H.264/H.265) up to 50MB</p>
                                    </div>
                                </div>
                            </div>
                            <div id="fileInfo" class="hidden flex items-center justify-between bg-white/5 px-4 py-2 rounded-xl border border-white/5 text-xs">
                                <span id="fileNameDisplay" class="truncate max-w-[200px]">video.mp4</span>
                                <span id="fileSizeDisplay" class="text-slate-500">0 MB</span>
                            </div>
                        </div>

                        <!-- Action Button -->
                        <button type="submit" id="submitBtn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-5 rounded-2xl transition shadow-lg shadow-blue-900/20 flex items-center justify-center space-x-2">
                            <span>Process Head Visual</span>
                            <i data-lucide="arrow-right" class="w-5 h-5"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Status Overlays -->
        <div id="statusModal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-6">
            <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
            <div class="glass-panel relative rounded-[40px] p-12 max-w-md w-full text-center shadow-2xl border border-white/20">
                <div id="loadingState" class="space-y-6">
                    <div class="w-24 h-24 bg-blue-600/20 rounded-full flex items-center justify-center mx-auto loading-pulse">
                        <i data-lucide="cpu" class="w-10 h-10 text-blue-500"></i>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold mb-2">Uploading Visual</h2>
                        <p id="loadingMessage" class="text-slate-400 text-sm">Streaming your recording to UNITH servers...</p>
                    </div>
                    <div class="w-full bg-white/5 h-1.5 rounded-full overflow-hidden">
                        <div id="progressBar" class="bg-blue-600 h-full w-0 transition-all duration-300"></div>
                    </div>
                </div>

                <div id="successState" class="hidden space-y-6">
                    <div class="w-24 h-24 bg-emerald-500/20 rounded-full flex items-center justify-center mx-auto">
                        <i data-lucide="sparkles" class="w-10 h-10 text-emerald-500"></i>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold mb-2">Visual Accepted</h2>
                        <p class="text-slate-400 text-sm">Upload complete. Your Digital Human is now in the generation queue. Check the platform for status updates.</p>
                    </div>
                    <button onclick="location.reload()" class="w-full bg-emerald-600 hover:bg-emerald-500 py-4 rounded-2xl font-bold transition">
                        Create Another
                    </button>
                </div>

                <div id="errorState" class="hidden space-y-6">
                    <div class="w-24 h-24 bg-red-500/20 rounded-full flex items-center justify-center mx-auto">
                        <i data-lucide="alert-triangle" class="w-10 h-10 text-red-500"></i>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold mb-2">Upload Failed</h2>
                        <p id="errorMessage" class="text-slate-400 text-sm">An error occurred during communication with the UNITH API.</p>
                    </div>
                    <button onclick="closeModal()" class="w-full bg-white/10 hover:bg-white/20 py-4 rounded-2xl font-bold transition">
                        Try Again
                    </button>
                </div>
            </div>
        </div>
    </main>

    <footer class="max-w-7xl mx-auto px-8 py-12 border-t border-white/5 text-center">
        <p class="text-slate-500 text-sm">© 2024 UNITH AI. All rights reserved.</p>
    </footer>

    <script>
        lucide.createIcons();

        const form = document.getElementById('uploadForm');
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('videoFile');
        const previewContainer = document.getElementById('previewContainer');
        const videoPreview = document.getElementById('videoPreview');
        const uploadPrompt = document.getElementById('uploadPrompt');
        const fileInfo = document.getElementById('fileInfo');
        const fileNameDisplay = document.getElementById('fileNameDisplay');
        const fileSizeDisplay = document.getElementById('fileSizeDisplay');
        const statusModal = document.getElementById('statusModal');
        const loadingState = document.getElementById('loadingState');
        const successState = document.getElementById('successState');
        const errorState = document.getElementById('errorState');
        const progressBar = document.getElementById('progressBar');
        const loadingMessage = document.getElementById('loadingMessage');
        const errorMessage = document.getElementById('errorMessage');

        // File Selection Handlers
        dropZone.addEventListener('click', () => { if (previewContainer.classList.contains('hidden')) fileInput.click(); });
        fileInput.addEventListener('change', (e) => { if (e.target.files[0]) handleFile(e.target.files[0]); });

        function handleFile(file) {
            if (file.type !== 'video/mp4') {
                showToast('Only MP4 files are supported', 'error');
                return;
            }
            fileNameDisplay.textContent = file.name;
            fileSizeDisplay.textContent = (file.size / (1024 * 1024)).toFixed(2) + ' MB';
            fileInfo.classList.remove('hidden');
            const url = URL.createObjectURL(file);
            videoPreview.src = url;
            videoPreview.play();
            previewContainer.classList.remove('hidden');
            uploadPrompt.classList.add('hidden');
        }

        function resetUpload() {
            fileInput.value = '';
            videoPreview.src = '';
            previewContainer.classList.add('hidden');
            uploadPrompt.classList.remove('hidden');
            fileInfo.classList.add('hidden');
        }

        function closeModal() {
            statusModal.classList.add('hidden');
            progressBar.style.width = '0%';
        }

        // Drag and Drop
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(ev => dropZone.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); }, false));
        dropZone.addEventListener('dragover', () => dropZone.classList.add('step-active'));
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('step-active'));
        dropZone.addEventListener('drop', (e) => {
            dropZone.classList.remove('step-active');
            if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
        });

        // ---------------------------------------------------------
        // API INTEGRATION WITH FETCH AND EXPONENTIAL BACKOFF
        // ---------------------------------------------------------

        async function uploadWithRetry(file, token, retries = 5, delay = 1000) {
            const formData = new FormData();
            formData.append('file', file);
            // Additional parameters like organization ID can be appended if needed by the specific endpoint
            // formData.append('org_id', 'YOUR_ORG_ID'); 

            try {
                const response = await fetch('https://platform-api.unith.ai/head-visuals', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`
                    },
                    body: formData
                });

                if (!response.ok) {
                    if (response.status === 401) throw new Error("Invalid or expired Bearer Token.");
                    if (response.status === 413) throw new Error("File size too large for UNITH servers.");
                    
                    if (retries > 0 && response.status >= 500) {
                        await new Promise(resolve => setTimeout(resolve, delay));
                        return uploadWithRetry(file, token, retries - 1, delay * 2);
                    }
                    throw new Error(`Server returned ${response.status}: ${response.statusText}`);
                }

                return await response.json();
            } catch (err) {
                if (retries > 0 && !err.message.includes("Token") && !err.message.includes("large")) {
                    await new Promise(resolve => setTimeout(resolve, delay));
                    return uploadWithRetry(file, token, retries - 1, delay * 2);
                }
                throw err;
            }
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const token = document.getElementById('bearerToken').value;
            const file = fileInput.files[0];

            if (!token || !file) {
                showToast('Token and video file are required.', 'error');
                return;
            }

            // UI State: Loading
            statusModal.classList.remove('hidden');
            loadingState.classList.remove('hidden');
            successState.classList.add('hidden');
            errorState.classList.add('hidden');
            progressBar.style.width = '30%'; // Initial simulated progress
            loadingMessage.textContent = "Streaming recording to UNITH...";

            try {
                const result = await uploadWithRetry(file, token);
                
                // UI State: Success
                progressBar.style.width = '100%';
                setTimeout(() => {
                    loadingState.classList.add('hidden');
                    successState.classList.remove('hidden');
                }, 500);

            } catch (err) {
                // UI State: Error
                loadingState.classList.add('hidden');
                errorState.classList.remove('hidden');
                errorMessage.textContent = err.message;
            }
        });

        function showToast(msg, type) {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-8 right-8 px-6 py-3 rounded-2xl shadow-xl z-[100] transition-all transform translate-y-20 border ${
                type === 'error' ? 'bg-red-500/20 border-red-500/50 text-red-200' : 'bg-emerald-500/20 border-emerald-500/50 text-emerald-200'
            }`;
            toast.innerHTML = `<div class="flex items-center space-x-2"><i data-lucide="${type === 'error' ? 'alert-circle' : 'check'}"></i><span>${msg}</span></div>`;
            document.body.appendChild(toast);
            lucide.createIcons();
            setTimeout(() => toast.classList.remove('translate-y-20'), 100);
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
                setTimeout(() => toast.remove(), 500);
            }, 3000);
        }
    </script>
</body>
</html>
